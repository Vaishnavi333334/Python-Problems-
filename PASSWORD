a=input("Enter your password: ")
up=0
lw=0
num=0
sp=0
if(len(a)>7):
    for i in a:
        if(i.isupper()):
            up+=1 
        elif(i.islower()):
            lw+=1 
        elif(i.isdigit()):
            num+=1 
        else:
            sp+=1 
    if(up>0 and lw>0 and num>0 and sp>0):
        print("Your Password is Strong!!!!")
    else:
        print("Oops Weak Password!!!")
else:
    print("Try Again")
